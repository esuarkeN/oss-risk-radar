{
  "name": "oss-risk-radar",
  "private": true,
  "packageManager": "npm@11.10.0",
  "workspaces": [
    "frontend/web",
    "shared/packages/schemas"
  ],
  "scripts": {
    "dev": "node scripts/dev/start.mjs",
    "dev:rebuild": "node scripts/dev/start.mjs --no-cache",
    "dev:down": "docker compose --profile apps down --remove-orphans",
    "dev:web": "npm --workspace @oss-risk-radar/web run dev",
    "build:web": "npm --workspace @oss-risk-radar/web run build",
    "lint:web": "npm --workspace @oss-risk-radar/web run lint",
    "ml:train": "node scripts/ml/trigger-run.mjs",
    "ml:train:force": "node scripts/ml/trigger-run.mjs --force",
    "ml:seed:foundation": "node scripts/ml/generate-foundation-seed.mjs",
    "ml:dataset": "node scripts/ml/build-dataset.mjs",
    "ml:dataset:foundation": "node scripts/ml/build-dataset.mjs build-all --generate-foundation-seed --foundation-target-repositories 2000",
    "ml:dataset:real-projects": "node scripts/ml/build-dataset.mjs build-all --seed-file scripts/ml/real-project-foundation-seed.csv --sample-limit-per-ecosystem 500 --minimum-repositories 40 --minimum-inactive-repositories 8",
    "ml:bootstrap": "node scripts/ml/bootstrap-training.mjs",
    "ml:bootstrap:foundation": "node scripts/ml/bootstrap-training.mjs --generate-foundation-seed --foundation-target-repositories 2000",
    "ml:bootstrap:real-projects": "node scripts/ml/bootstrap-training.mjs --seed-file scripts/ml/real-project-foundation-seed.csv --sample-limit-per-ecosystem 500 --minimum-repositories 40 --minimum-inactive-repositories 8",
    "ml:bootstrap:force": "node scripts/ml/bootstrap-training.mjs --force",
    "ml:stage-training": "node scripts/ml/stage-training-artifacts.mjs",
    "thesis:build": "powershell -ExecutionPolicy Bypass -File tex/thesis/scripts/build.ps1",
    "thesis:watch": "powershell -ExecutionPolicy Bypass -File tex/thesis/scripts/build.ps1 -Watch",
    "thesis:clean": "powershell -ExecutionPolicy Bypass -File tex/thesis/scripts/clean.ps1",
    "test:api": "cd backend/api && go test ./...",
    "test:scoring": "cd mltraining/scoring && python -m pytest tests",
    "check:web": "npm run lint:web && npm run build:web"
  }
}
